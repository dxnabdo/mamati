    "next": "14.0.0",
    "openai": "^6.33.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-speech-recognition": "^4.0.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "swiper": "^12.1.3",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "chokidar": "^3.6.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5"
  },
  "engines": {

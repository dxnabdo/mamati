  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "vercel-build": "npm install --legacy-peer-deps && npm run build",
    "watch": "node scripts/watch-desktop.js",
    "watch:dev": "concurrently \"npm run dev\" \"npm run watch\"",
    "clean": "rm -rf .next node_modules",
    "clean:win": "rmdir /s /q .next && rmdir /s /q node_modules",
    "reinstall": "npm run clean && npm install",
    "reinstall:win": "npm run clean:win && npm install"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "firebase": "^12.10.0",
    "framer-motion": "^10.16.4",
